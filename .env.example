# LiveKit Cloud — get these from https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=secret_xxxxxxxxxxxxxxxxxxxx

# AI providers — only OpenAI needed (used for STT + LLM + TTS)
OPENAI_API_KEY=sk-...

# Flask token server
PORT=5000
